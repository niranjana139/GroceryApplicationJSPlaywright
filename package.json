{
  "name": "playwrightgroceryapplication",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "admintest": "npx playwright test specs/admincreation.spec.js",
    "logintest": "npx playwright test specs/login.spec.js",
    "endtoendtest": "npx playwright test specs/endtoend.spec.js",
    "invalidlogintest": "npx playwright test specs/invalidlogin.spec.js",
    "report": "npx allure generate ./allure-results --clean",
    "open": "npx allure open ./allure-report",
    "trace": "powershell -Command \"$file = Get-ChildItem -Path test-results -Recurse -Filter trace.zip | Sort-Object LastWriteTime -Descending | Select-Object -First 1; if ($file) { npx playwright show-trace \\\"$($file.FullName)\\\" } else { Write-Host 'No trace found' }\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@types/node": "^24.0.3",
    "allure-commandline": "^2.34.1",
    "allure-playwright": "^3.8.0",
    "exceljs": "^4.4.0"
  }
}
